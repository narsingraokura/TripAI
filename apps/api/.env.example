# Replace the incomplete env template with one that lists every setting, so Railway configuration becomes a checklist.
# ============================================================
# Database (Supabase) — same values for local and production
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ============================================================
# LLM providers
# ============================================================
ANTHROPIC_API_KEY=your-anthropic-api-key
# Main chat + suggestions model. Short alias, NOT the long dated version.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Cheaper model for guardrail classifier (if/when implemented)
ANTHROPIC_CLASSIFIER_MODEL=claude-haiku-4-5

OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# Vector store (Qdrant)
# Local dev: http://localhost:6333, no API key
# Production: Qdrant Cloud URL + API key
# ============================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tripai_docs

# ============================================================
# CORS — which frontend URLs are allowed to call this backend
# Comma-separated. Local dev uses just localhost. Production adds Vercel URL.
# ============================================================
CORS_ORIGINS=http://localhost:3000

# ============================================================
# Admin API key — required for all write endpoints (PATCH, POST, DELETE)
# Fail closed: if unset or empty, all writes are blocked.
# Generate with: openssl rand -hex 32
# ============================================================
ADMIN_API_KEY=your-secret-key-here